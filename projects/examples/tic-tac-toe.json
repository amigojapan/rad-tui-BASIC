  "code": "def on_form_load():\n    global board, game_over\n    board = [\" \"] * 9\n    game_over = False\n    lbl_status.caption = \"Your turn (X)\"\n    update_ui()\n\ndef update_ui():\n    btn0.caption = board[0]\n    btn1.caption = board[1]\n    btn2.caption = board[2]\n    btn3.caption = board[3]\n    btn4.caption = board[4]\n    btn5.caption = board[5]\n    btn6.caption = board[6]\n    btn7.caption = board[7]\n    btn8.caption = board[8]\n\ndef check_win(b, p):\n    wins = [(0,1,2),(3,4,5),(6,7,8),(0,3,6),(1,4,7),(2,5,8),(0,4,8),(2,4,6)]\n    for w in wins:\n        if b[w[0]] == b[w[1]] == b[w[2]] == p:\n            return True\n    return False\n\ndef is_full(b):\n    return \" \" not in b\n\ndef ai_move():\n    global game_over\n    if game_over: return\n    import random\n    empty = [i for i, v in enumerate(board) if v == \" \"]\n    if not empty: return\n    \n    move = -1\n    # 1. Try to win\n    for e in empty:\n        b2 = list(board)\n        b2[e] = \"O\"\n        if check_win(b2, \"O\"):\n            move = e; break\n    \n    # 2. Try to block player\n    if move == -1:\n        for e in empty:\n            b2 = list(board)\n            b2[e] = \"X\"\n            if check_win(b2, \"X\"):\n                move = e; break\n                \n    # 3. Random empty slot\n    if move == -1:\n        move = random.choice(empty)\n        \n    board[move] = \"O\"\n    update_ui()\n    if check_win(board, \"O\"):\n        lbl_status.caption = \"AI Wins!\"\n        game_over = True\n    elif is_full(board):\n        lbl_status.caption = \"Draw!\"\n        game_over = True\n    else:\n        lbl_status.caption = \"Your turn (X)\"\n\ndef player_move(idx):\n    global game_over\n    if game_over or board[idx] != \" \": return\n    board[idx] = \"X\"\n    update_ui()\n    if check_win(board, \"X\"):\n        lbl_status.caption = \"You Win!\"\n        game_over = True\n    elif is_full(board):\n        lbl_status.caption = \"Draw!\"\n        game_over = True\n    else:\n        lbl_status.caption = \"AI thinking...\"\n        ai_move()\n\ndef reset_game():\n    on_form_load()\n"
